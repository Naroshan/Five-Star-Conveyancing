# Copy to .env.local and set a real connection string.
# NEVER commit .env.local or a real DATABASE_URL to source control.
DATABASE_URL=postgres://user:password@localhost:5432/five_star_data

# Used by sitemap.ts/robots.ts to build absolute URLs. Falls back to the
# production domain if unset — override locally only if testing against a
# different host.
NEXT_PUBLIC_SITE_URL=https://fivestarconveyancing.co.uk
